generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  PAUSED
  POSTPONED
  CANCELLED
  FINISHED
}

enum MatchOutcome {
  HOME
  DRAW
  AWAY
}

enum LeagueType {
  GLOBAL
  PRIVATE
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum StageType {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  email                   String                   @unique
  passwordHash            String?                  @map("password_hash")
  displayName             String                   @map("display_name")
  avatarUrl               String?                  @map("avatar_url")
  registrationTimestamp   DateTime                 @default(now()) @map("registration_timestamp") @db.Timestamptz(6)
  globalPoints            Int                      @default(0) @map("global_points")
  exactScoresCount        Int                      @default(0) @map("exact_scores_count")
  correctOutcomesCount    Int                      @default(0) @map("correct_outcomes_count")
  isAdmin                 Boolean                  @default(false) @map("is_admin")
  isBanned                Boolean                  @default(false) @map("is_banned")
  banReason               String?                  @map("ban_reason")
  bannedAt                DateTime?                @map("banned_at") @db.Timestamptz(6)
  onboardingCompletedAt   DateTime?                @map("onboarding_completed_at") @db.Timestamptz(6)
  predictions             Prediction[]
  outrights               Outright?
  leagueMemberships       LeagueMember[]
  oauthAccounts           OAuthAccount[]
  sessions                UserSession[]
  notificationPreferences NotificationPreference[]
  notificationDeliveries  NotificationDelivery[]
  rankSnapshots           LeagueRankSnapshot[]
  shareCards              ShareCard[]
  announcementViews       AnnouncementView[]
  passwordResetTokens     PasswordResetToken[]

  @@index([globalPoints(sort: Desc), exactScoresCount(sort: Desc), registrationTimestamp(sort: Asc)], map: "leaderboard_tiebreaker_idx")
  @@index([isBanned])
  @@map("users")
}

model AdminAccount {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  isSuperAdmin Boolean  @default(false) @map("is_super_admin")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_accounts")
}

model OAuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model UserSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model Tournament {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  slug                String               @unique
  externalId          String?              @unique @map("external_id")
  startsAt            DateTime             @map("starts_at") @db.Timestamptz(6)
  endsAt              DateTime?            @map("ends_at") @db.Timestamptz(6)
  syncFromAt          DateTime?            @map("sync_from_at") @db.Timestamptz(6)
  hostCountries       String[]             @default([]) @map("host_countries")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  teams               Team[]
  players             Player[]
  matches             Match[]
  outrights           Outright[]
  outrightSettlements OutrightSettlement[]

  @@index([isActive, startsAt])
  @@map("tournaments")
}

model Team {
  id                  String     @id @default(uuid()) @db.Uuid
  tournamentId        String     @map("tournament_id") @db.Uuid
  externalId          String?    @map("external_id")
  name                String
  shortName           String?    @map("short_name")
  flagEmoji           String?    @map("flag_emoji")
  groupName           String?    @map("group_name")
  tournament          Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players             Player[]
  homeMatches         Match[]    @relation("HomeTeam")
  awayMatches         Match[]    @relation("AwayTeam")
  championPicks       Outright[] @relation("ChampionTeam")
  secondRunnerUpPicks Outright[] @relation("SecondRunnerUpTeam")
  fairPlayPicks       Outright[] @relation("FairPlayTeam")

  @@unique([tournamentId, name])
  @@unique([tournamentId, externalId])
  @@index([tournamentId, groupName])
  @@map("teams")
}

model Player {
  id                     String               @id @default(uuid()) @db.Uuid
  tournamentId           String               @map("tournament_id") @db.Uuid
  teamId                 String?              @map("team_id") @db.Uuid
  externalId             String?              @map("external_id")
  name                   String
  sequenceNumber         Int?                 @map("sequence_number")
  position               String?
  isGoalkeeper           Boolean              @default(false) @map("is_goalkeeper")
  source                 String               @default("API")
  tournament             Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team                   Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  bestPlayerPicks        Outright[]           @relation("BestPlayer")
  bestGoalkeeperPicks    Outright[]           @relation("BestGoalkeeper")
  goldenBootPicks        Outright[]           @relation("GoldenBoot")
  youngPlayerPicks       Outright[]           @relation("YoungPlayer")
  goldenBallSettlements  OutrightSettlement[] @relation("GoldenBallWinner")
  goldenGloveSettlements OutrightSettlement[] @relation("GoldenGloveWinner")

  @@unique([tournamentId, externalId])
  @@index([tournamentId, isGoalkeeper])
  @@index([tournamentId, sequenceNumber])
  @@index([tournamentId, source])
  @@index([teamId])
  @@map("players")
}

model Match {
  id                     Int                    @id
  tournamentId           String?                @map("tournament_id") @db.Uuid
  externalId             String?                @unique @map("external_id")
  matchday               Int?
  stage                  StageType              @default(GROUP)
  groupName              String?                @map("group_name")
  homeTeam               String                 @map("home_team")
  awayTeam               String                 @map("away_team")
  homeTeamId             String?                @map("home_team_id") @db.Uuid
  awayTeamId             String?                @map("away_team_id") @db.Uuid
  venue                  String?
  kickoffTime            DateTime               @map("kickoff_time") @db.Timestamptz(6)
  status                 MatchStatus            @default(SCHEDULED)
  isEnabled              Boolean                @default(true) @map("is_enabled")
  homeScore              Int?                   @map("home_score")
  awayScore              Int?                   @map("away_score")
  homeScore90            Int?                   @map("home_score_90")
  awayScore90            Int?                   @map("away_score_90")
  lastSyncedAt           DateTime?              @map("last_synced_at") @db.Timestamptz(6)
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tournament             Tournament?            @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  homeTeamRef            Team?                  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeamRef            Team?                  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  predictions            Prediction[]
  notificationDeliveries NotificationDelivery[]
  shareCardItems         ShareCardItem[]

  @@index([matchday, kickoffTime])
  @@index([status, kickoffTime])
  @@index([isEnabled, kickoffTime])
  @@index([tournamentId, stage, kickoffTime])
  @@map("matches")
}

model Prediction {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  matchId            Int           @map("match_id")
  predictedOutcome   MatchOutcome? @map("predicted_outcome")
  predictedHomeScore Int?          @map("predicted_home_score")
  predictedAwayScore Int?          @map("predicted_away_score")
  pointsAwarded      Int?          @map("points_awarded")
  isExactScore       Boolean       @default(false) @map("is_exact_score")
  isCorrectOutcome   Boolean       @default(false) @map("is_correct_outcome")
  isLocked           Boolean       @default(false) @map("is_locked")
  submittedAt        DateTime      @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  scoredAt           DateTime?     @map("scored_at") @db.Timestamptz(6)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  match              Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId, submittedAt])
  @@map("predictions")
}

model Outright {
  userId             String      @id @map("user_id") @db.Uuid
  tournamentId       String?     @map("tournament_id") @db.Uuid
  championTeamId     String      @map("champion_team_id") @db.Uuid
  secondRunnerUpTeamId String    @map("second_runner_up_team_id") @db.Uuid
  fairPlayTeamId     String      @map("fair_play_team_id") @db.Uuid
  bestPlayerId       String      @map("best_player_id") @db.Uuid
  bestGkId           String      @map("best_gk_id") @db.Uuid
  goldenBootPlayerId String      @map("golden_boot_player_id") @db.Uuid
  youngPlayerId      String      @map("young_player_id") @db.Uuid
  pointsAwarded      Int?        @map("points_awarded")
  submittedAt        DateTime    @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament         Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  championTeam       Team        @relation("ChampionTeam", fields: [championTeamId], references: [id], onDelete: Restrict)
  secondRunnerUpTeam Team        @relation("SecondRunnerUpTeam", fields: [secondRunnerUpTeamId], references: [id], onDelete: Restrict)
  fairPlayTeam       Team        @relation("FairPlayTeam", fields: [fairPlayTeamId], references: [id], onDelete: Restrict)
  bestPlayer         Player      @relation("BestPlayer", fields: [bestPlayerId], references: [id], onDelete: Restrict)
  bestGoalkeeper     Player      @relation("BestGoalkeeper", fields: [bestGkId], references: [id], onDelete: Restrict)
  goldenBoot         Player      @relation("GoldenBoot", fields: [goldenBootPlayerId], references: [id], onDelete: Restrict)
  youngPlayer        Player      @relation("YoungPlayer", fields: [youngPlayerId], references: [id], onDelete: Restrict)

  @@index([tournamentId])
  @@map("outrights")
}

model League {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  joinCode      String               @unique @map("join_code") @db.VarChar(8)
  type          LeagueType           @default(PRIVATE)
  ownerUserId   String?              @map("owner_user_id") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  memberships   LeagueMember[]
  rankSnapshots LeagueRankSnapshot[]

  @@index([type])
  @@map("leagues")
}

model LeagueMember {
  leagueId String   @map("league_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([leagueId, userId])
  @@index([userId])
  @@map("league_members")
}

model LeagueRankSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @map("league_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  rank        Int
  totalPoints Int      @map("total_points")
  capturedAt  DateTime @default(now()) @map("captured_at") @db.Timestamptz(6)
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, capturedAt])
  @@index([leagueId, capturedAt])
  @@index([userId, capturedAt])
  @@map("league_rank_snapshots")
}

model NotificationPreference {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  endpoint  String
  isEnabled Boolean             @default(true) @map("is_enabled")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, endpoint])
  @@index([userId, isEnabled])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id           String              @id @default(uuid()) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  matchId      Int?                @map("match_id")
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)
  payload      Json
  error        String?
  scheduledFor DateTime            @map("scheduled_for") @db.Timestamptz(6)
  sentAt       DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  match        Match?              @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([userId, createdAt])
  @@map("notification_deliveries")
}

model ShareCard {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  shareDate DateTime        @map("share_date") @db.Date
  title     String
  body      String
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ShareCardItem[]

  @@unique([userId, shareDate])
  @@map("share_cards")
}

model ShareCardItem {
  shareCardId        String    @map("share_card_id") @db.Uuid
  matchId            Int       @map("match_id")
  predictedHomeScore Int       @map("predicted_home_score")
  predictedAwayScore Int       @map("predicted_away_score")
  shareCard          ShareCard @relation(fields: [shareCardId], references: [id], onDelete: Cascade)
  match              Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@id([shareCardId, matchId])
  @@index([matchId])
  @@map("share_card_items")
}

model Announcement {
  id          String             @id @default(uuid()) @db.Uuid
  title       String
  description String             @db.Text
  imageUrl    String             @map("image_url") @db.Text
  linkUrl     String             @map("link_url") @db.Text
  isActive    Boolean            @default(true) @map("is_active")
  displayFrequencyHours Int       @default(24) @map("display_frequency_hours")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  views       AnnouncementView[]

  @@index([isActive, createdAt])
  @@map("announcements")
}

model AnnouncementView {
  id             String       @id @default(uuid()) @db.Uuid
  announcementId String       @map("announcement_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  seenAt         DateTime     @default(now()) @map("seen_at") @db.Timestamptz(6)
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId, seenAt])
  @@map("announcement_views")
}

model AppSetting {
  id               Int      @id @default(1)
  announcementText String?  @map("announcement_text")
  bannerImageUrl   String?  @map("banner_image_url")
  loginBackgroundImageUrl String? @map("login_background_image_url")
  maintenanceMode  Boolean  @default(false) @map("maintenance_mode")
  playerCatalogSource String @default("API") @map("player_catalog_source")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("app_settings")
}

model AdminJobStatus {
  key           String    @id
  label         String
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz(6)
  lastSuccessAt DateTime? @map("last_success_at") @db.Timestamptz(6)
  lastError     String?   @map("last_error")
  lastPayload   Json?     @map("last_payload")
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_job_statuses")
}

model OutrightSettlement {
  id                  String     @id @default(uuid()) @db.Uuid
  tournamentId        String     @unique @map("tournament_id") @db.Uuid
  goldenBallPlayerId  String     @map("golden_ball_player_id") @db.Uuid
  goldenGlovePlayerId String     @map("golden_glove_player_id") @db.Uuid
  settledAt           DateTime   @default(now()) @map("settled_at") @db.Timestamptz(6)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  tournament          Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  goldenBallPlayer    Player     @relation("GoldenBallWinner", fields: [goldenBallPlayerId], references: [id], onDelete: Restrict)
  goldenGlovePlayer   Player     @relation("GoldenGloveWinner", fields: [goldenGlovePlayerId], references: [id], onDelete: Restrict)

  @@index([settledAt])
  @@map("outright_settlements")
}
