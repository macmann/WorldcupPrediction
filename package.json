{
  "name": "football-fantasy-myanmar-wc-2026",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "next dev",
    "dev:web:clean": "npm run clean:next && next dev",
    "dev:worker": "node --env-file=.env --import tsx src/jobs/runtime.ts",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:worker\"",
    "build": "next build",
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "worker": "node --env-file=.env --import tsx src/jobs/runtime.ts",
    "scheduler": "node --env-file=.env --import tsx src/jobs/scheduler.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "postinstall": "prisma generate",
    "render-build": "prisma generate && next build",
    "render-start": "next start"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "next": "^14.2.18",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "zod": "^3.23.8",
    "framer-motion": "^11.11.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
