# PostgreSQL database
# Use the direct connection string from Neon or Supabase. Keep sslmode=require for managed/serverless Postgres.
DATABASE_URL="postgresql://[user]:[password]@[neon_or_supabase_host]/[db]?sslmode=require"

# Redis for BullMQ background queues
# Use the TLS Redis URL from Upstash or another managed Redis provider.
REDIS_URL="rediss://[user]:[password]@[upstash_host]:[port]"

# Application URL
# Set this to your local URL in development and your deployed HTTPS URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth/session secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-secret"
JWT_SECRET="replace-with-a-strong-secret"

# Football data provider
FOOTBALL_API_PROVIDER="football-data"
FOOTBALL_API_BASE_URL="https://api.football-data.org/v4"
FOOTBALL_API_KEY="replace-with-your-football-api-key"
WORLD_CUP_COMPETITION_CODE="WC"

# Tournament settings
TOURNAMENT_START_TIME="2026-06-11T00:00:00.000Z"
